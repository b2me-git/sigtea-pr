{
  "name": "sigtea-pr",
  "version": "1.0.0",
  "description": "SIGTEA/PR - Mobile App (Expo + React Native + TypeScript)",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:web": "expo start --web",
    "start:ios": "expo start --ios",
    "start:android": "expo start --android",
    "build": "eas build",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "preview": "eas build --platform ios --local",
    "submit": "eas submit",
    "type-check": "tsc --noEmit",
    "lint": "eslint --ext .ts,.tsx src/",
    "lint:fix": "eslint --ext .ts,.tsx src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prebuild": "expo prebuild --clean",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "prebuild:android": "expo prebuild --platform android --clean",
    "clean": "rm -rf node_modules .expo dist .turbo",
    "prepare": "husky install"
  },
  "dependencies": {
    "expo": "~51.0.0",
    "expo-router": "~3.5.0",
    "expo-splash-screen": "~0.27.0",
    "expo-status-bar": "~1.12.0",
    "expo-font": "~12.0.0",
    "expo-constants": "~16.0.0",
    "expo-linking": "~6.0.0",
    "react": "18.2.0",
    "react-native": "0.74.0",
    "react-native-screens": "~3.31.0",
    "react-native-safe-area-context": "4.10.1",
    "react-native-gesture-handler": "~2.14.0",
    "@react-navigation/native": "^6.1.0",
    "@tanstack/react-query": "^5.40.0",
    "zustand": "^4.4.0",
    "react-hook-form": "^7.50.0",
    "zod": "^3.22.0",
    "@supabase/supabase-js": "^2.39.0",
    "axios": "^1.6.0",
    "date-fns": "^2.30.0"
  },
  "devDependencies": {
    "@types/react": "~18.2.45",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.3.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-native": "^4.1.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.1.0",
    "jest": "^29.7.0",
    "@testing-library/react-native": "^12.4.3",
    "husky": "^8.0.0",
    "lint-staged": "^15.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "expo": {
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ]
  }
}
